# Cortex Capital - Production Environment Variables
# Copy to .env on Render

# Database
DATABASE_URL=postgresql://...@render.com/cortex_capital

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App URLs
APP_URL=https://cortexcapital.com
NEXT_PUBLIC_API_URL=https://cortexcapital.com

# Broker OAuth (optional - falls back to manual token entry)
TRADIER_CLIENT_ID=
TRADIER_CLIENT_SECRET=
TRADIER_REDIRECT_URI=https://cortexcapital.com/api/broker/tradier/callback

ALPACA_CLIENT_ID=
ALPACA_CLIENT_SECRET=
ALPACA_REDIRECT_URI=https://cortexcapital.com/api/broker/alpaca/callback

# DeepSeek (agent conversations)
DEEPSEEK_API_KEY=

# Features
ENABLE_DISCUSSIONS=true
ENABLE_SCHEDULER=true
NODE_ENV=production

# JWT
JWT_SECRET=change-this-to-a-random-string
