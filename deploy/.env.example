# Environment Variables Template for Deployment
# Copy relevant sections to your deployment platform

# ======================
# PRODUCTION DEPLOYMENT
# ======================

# --- BACKEND (Railway) ---

# Database (Render Postgres)
DATABASE_URL=postgresql://user:password@host.render.com:5432/cortex_capital?sslmode=require

# Tradier API (PRODUCTION - use real API)
TRADIER_TOKEN=your_production_tradier_token
TRADIER_BASE_URL=https://api.tradier.com

# Security (GENERATE NEW FOR PRODUCTION)
JWT_SECRET=generate_with_openssl_rand_hex_64
ENCRYPTION_KEY=generate_32_character_key

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
SUPPORT_EMAIL=support@cortexcapital.ai

# Application
APP_URL=https://app.cortexcapital.ai
PORT=3000
NODE_ENV=production

# CORS (add all frontend domains)
ALLOWED_ORIGINS=https://app.cortexcapital.ai,https://cortex-capital-frontend.vercel.app

# Logging
LOG_LEVEL=info

# Optional: Monitoring
SENTRY_DSN=https://xxx@sentry.io/xxx

# --- FRONTEND (Vercel) ---

# API URL (points to Railway backend)
NEXT_PUBLIC_API_URL=https://api.cortexcapital.ai


# ======================
# STAGING DEPLOYMENT
# ======================

# --- BACKEND (Railway Staging Environment) ---

DATABASE_URL=postgresql://user:password@staging-host.render.com:5432/cortex_staging?sslmode=require
TRADIER_TOKEN=staging_token
TRADIER_BASE_URL=https://sandbox.tradier.com
JWT_SECRET=staging_jwt_secret_different_from_prod
ENCRYPTION_KEY=staging_encryption_key_32_chars
RESEND_API_KEY=re_staging_key
SUPPORT_EMAIL=staging@cortexcapital.ai
APP_URL=https://staging.cortexcapital.ai
NODE_ENV=staging
ALLOWED_ORIGINS=https://staging.cortexcapital.ai,https://cortex-capital-frontend-git-develop.vercel.app
LOG_LEVEL=debug

# --- FRONTEND (Vercel Preview) ---

NEXT_PUBLIC_API_URL=https://cortex-capital-staging.up.railway.app


# ======================
# LOCAL DEVELOPMENT
# ======================

# --- BACKEND (Local) ---

DATABASE_URL=postgresql://cortex:cortex_local_password@localhost:5432/cortex_capital
TRADIER_TOKEN=sandbox_token
TRADIER_BASE_URL=https://sandbox.tradier.com
JWT_SECRET=local_dev_jwt_secret_not_for_production
ENCRYPTION_KEY=local_dev_encryption_key_32ch
RESEND_API_KEY=re_dev_key
SUPPORT_EMAIL=dev@localhost
APP_URL=http://localhost:3001
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
LOG_LEVEL=debug

# --- FRONTEND (Local) ---

NEXT_PUBLIC_API_URL=http://localhost:3000


# ======================
# GENERATION COMMANDS
# ======================

# Generate JWT Secret (64 bytes):
# openssl rand -hex 64

# Generate Encryption Key (32 bytes):
# openssl rand -hex 32
