# Cortex Capital - Multi-User Portfolio & Tier Gating
# Copy to .env.local and fill in your values

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# JWT Secret (change in production)
JWT_SECRET=replace_with_a_long_random_secret

# Broker Encryption Key (CRITICAL - rotate in production)
BROKER_ENCRYPTION_KEY=replace_with_a_32_plus_char_encryption_secret

# Alpaca OAuth (Live)
ALPACA_CLIENT_ID=your_alpaca_client_id
ALPACA_CLIENT_SECRET=your_alpaca_secret
ALPACA_REDIRECT_URI=http://localhost:3000/api/broker/callback

# Alpaca Paper (Demo fallback)
ALPACA_API_KEY=your_paper_api_key
ALPACA_SECRET_KEY=your_paper_secret_key

# Tradier OAuth
TRADIER_CLIENT_ID=your_tradier_client_id
TRADIER_CLIENT_SECRET=your_tradier_secret
TRADIER_REDIRECT_URI=http://localhost:3000/api/broker/callback

# Guardian Cron Secret
GUARDIAN_SECRET=replace_with_a_random_cron_secret

# SnapTrade - Universal Broker API
SNAPTRADE_CLIENT_ID=your_client_id
SNAPTRADE_CONSUMER_KEY=your_consumer_key

# Brave Search API for Research Engine
# Get your key from: https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here
