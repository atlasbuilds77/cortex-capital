# Cortex Capital - Environment Variables Template
# Copy to .env and fill in your values

# ======================
# DATABASE (Required)
# ======================
DATABASE_URL=postgresql://user:password@localhost:5432/cortex_capital?sslmode=require

# ======================
# TRADIER API (Required)
# ======================
# Get your token from: https://developer.tradier.com
TRADIER_TOKEN=your_tradier_token_here
# Use sandbox.tradier.com for testing, api.tradier.com for production
TRADIER_BASE_URL=https://sandbox.tradier.com

# ======================
# ALPACA API (Optional - for live trading)
# ======================
# Get your keys from: https://alpaca.markets
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret
# Use paper-api.alpaca.markets for paper trading, api.alpaca.markets for live
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ======================
# STRIPE (Required for payments)
# ======================
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Get from Stripe Dashboard → Webhooks → Add endpoint
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ======================
# SECURITY (Required for Production)
# ======================
# Generate: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_here_generate_with_openssl_rand_hex_64
# Generate: openssl rand -base64 32 (must be exactly 32 characters)
ENCRYPTION_KEY=your_32_character_encryption_key

# ======================
# EMAIL / RESEND (Required for emails)
# ======================
# Get API key from: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Your "from" email address (must be verified in Resend)
FROM_EMAIL=Cortex Capital <noreply@cortexcapital.ai>

# ======================
# OAUTH (Optional - for social login)
# ======================
# Google OAuth - https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Apple OAuth - https://developer.apple.com/account/resources/identifiers
APPLE_CLIENT_ID=your_apple_client_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY=your_apple_private_key

# ======================
# APPLICATION
# ======================
# Backend server port
PORT=3000
# Frontend URL (no trailing slash)
APP_URL=http://localhost:3001
# For production:
# APP_URL=https://app.cortexcapital.ai
NEXT_PUBLIC_API_URL=http://localhost:3000
# Environment: development | production | test
NODE_ENV=development
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ======================
# LOGGING
# ======================
# debug | info | warn | error
LOG_LEVEL=info

# ======================
# MONITORING (Optional)
# ======================
# Sentry DSN for error tracking
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ======================
# RATE LIMITING (Optional - has defaults)
# ======================
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW=60000

# ======================
# FEATURE FLAGS (Optional)
# ======================
# Enable real trade execution (dangerous!)
# ENABLE_REAL_TRADES=false
# Enable dry run mode (logs trades but doesn't execute)
DRY_RUN=true
