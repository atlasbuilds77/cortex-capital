{
  "name": "cortex-capital",
  "version": "2.0.0",
  "description": "AI-powered portfolio management with ANALYST, STRATEGIST, EXECUTOR, and REPORTER agents",
  "main": "dist/server.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "dev": "tsx watch server.ts",
    "start": "NODE_ENV=production tsx server.ts",
    "build": "tsc && cd frontend && npm run build",
    "build:backend": "tsc",
    "build:frontend": "cd frontend && npm run build",
    "test": "tsx test-phase2.ts",
    "test:engine": "tsx test-engine.ts",
    "test:scheduler": "tsx test-scheduler.ts",
    "test:unit": "node --test tests/*.test.ts",
    "scheduler": "tsx services/scheduler.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "for f in migrations/*.sql; do psql \"$DATABASE_URL\" -f \"$f\"; done",
    "db:migrate:all": "for f in migrations/*.sql; do psql \"$DATABASE_URL\" -f \"$f\"; done",
    "deploy": "./scripts/deploy.sh",
    "deploy:prod": "./scripts/deploy.sh production"
  },
  "keywords": [
    "portfolio",
    "trading",
    "ai",
    "rebalancing",
    "tradier"
  ],
  "author": "Cortex Capital",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/rate-limit": "^8.1.0",
    "@fastify/static": "^7.0.4",
    "@supabase/supabase-js": "^2.99.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "fastify-raw-body": "^4.3.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "openai": "^6.32.0",
    "pg": "^8.11.0",
    "pino": "^8.19.0",
    "pino-pretty": "^13.1.3",
    "resend": "^6.9.4",
    "stripe": "^20.4.1",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
